{
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/data/(.*)", "destination": "/data/$1" }
  ]
}
